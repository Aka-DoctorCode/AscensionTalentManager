package-as: AscensionTalentManager
ignore:
    - .git
    - .gitignore
    - .vscode
    - .pkgmeta
    - __MACOSX
    - .DS_Store

externals:
  Libs/LibStub:
    url: https://github.com/Lua-wow/LibStub/trunk
  Libs/CallbackHandler-1.0:
    url: https://github.com/Lua-wow/CallbackHandler/trunk
  Libs/AceAddon-3.0:
    url: https://github.com/Ace3/Ace3/trunk/AceAddon-3.0
  Libs/AceEvent-3.0:
    url: https://github.com/Ace3/Ace3/trunk/AceEvent-3.0
  Libs/AceDB-3.0:
    url: https://github.com/Ace3/Ace3/trunk/AceDB-3.0
  Libs/AceDBOptions-3.0:
    url: https://github.com/Ace3/Ace3/trunk/AceDBOptions-3.0
  Libs/AceGUI-3.0:
    url: https://github.com/Ace3/Ace3/trunk/AceGUI-3.0
  Libs/AceConfig-3.0:
    url: https://github.com/Ace3/Ace3/trunk/AceConfig-3.0
  Libs/AceConsole-3.0:
    url: https://github.com/Ace3/Ace3/trunk/AceConsole-3.0
  Libs/AceHook-3.0:
    url: https://github.com/Ace3/Ace3/trunk/AceHook-3.0
  Libs/AceSerializer-3.0:
    url: https://github.com/Ace3/Ace3/trunk/AceSerializer-3.0
  # Si LibTalentTree te sigue dando error, intenta buscar su repo en GitHub o verifica que la URL de WowAce sea exactamente la que ellos proveen en su página
  Libs/LibTalentTree-1.0:
    url: https://repos.wowace.com/wow/libtalenttree-1-0/mainline/trunk
  Libs/LibVersionCheck-1.0:
    url: https://repos.wowace.com/wow/libversioncheck-1-0/mainline/trunk